# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]

# Distribution / packaging
build/
dist/
*.egg-info/
README.md

# Virtual environments
.venv/
.env/

# Poetry artifacts
poetry.lock

# Editor-specific
.idea/
.vscode/

# OS metadata
.DS_Store
Thumbs.db
# Ignore the *contents* of .claude/ (session state, settings, ...)
# rather than the directory itself, so re-includes below work — git
# refuses to re-include files inside a fully-ignored parent.
.claude/*
# Project-local skills travel with the repo.
!.claude/skills/

# Coverage artifacts
.coverage
htmlcov/
coverage.xml
scripts/fetch-agent-branches.sh
